# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV="development"
PORT=3000

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/gearup_db"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-characters"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================================
# STRIPE PAYMENT GATEWAY
# ============================================================
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# ============================================================
# APPLICATION SETTINGS
# ============================================================
DEFAULT_CURRENCY="USD"
MAX_RENTAL_DAYS=30
MAX_RENTAL_ITEMS=20
MAX_ITEMS_PER_ORDER=10
BCRYPT_ROUNDS=10

# ============================================================
# RATE LIMITING
# ============================================================
# Strict rate limiting (sensitive operations like auth)
STRICT_WINDOW_MS=900000          # 15 minutes in milliseconds
STRICT_MAX_REQUESTS=5

# Authentication rate limiting
AUTH_WINDOW_MS=3600000           # 1 hour in milliseconds
AUTH_MAX_REQUESTS=10

# Standard rate limiting
STANDARD_WINDOW_MS=900000        # 15 minutes in milliseconds
STANDARD_MAX_REQUESTS=100


# FILE UPLOAD

MAX_FILE_SIZE=5242880            # 5MB in bytes
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp"
UPLOAD_DIR="./uploads"


# LOGGING

LOG_LEVEL="info"                 # debug, info, warn, error
LOG_FORMAT="json"                # json or pretty
LOG_FILE="./logs/app.log"




# VALIDATION RULES

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE="true"
PASSWORD_REQUIRE_LOWERCASE="true"
PASSWORD_REQUIRE_NUMBER="true"
PASSWORD_REQUIRE_SPECIAL="false"
MAX_SEARCH_LENGTH=100
MAX_COMMENT_LENGTH=1000
MAX_NOTES_LENGTH=500

# FEATURE FLAGS

ENABLE_REGISTRATION="true"
ENABLE_SOCIAL_LOGIN="false"
MAINTENANCE_MODE="false"
