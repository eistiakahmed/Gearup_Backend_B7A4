// User model and authentication
// Handles all user types: customers, providers, and administrators



model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  role            UserRole  @default(CUSTOMER)
  phoneNumber     String?
  address         String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  gearItems       GearItem[]
  rentalOrders    RentalOrder[]
  payments        Payment[]
  reviews         Review[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}